

generator client {
  provider   = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model BotQuestion {
  id        String      @id @default(uuid())
  text      String
  order     Int
  options   String?     // JSON string com opções válidas, ex: '["Sim","Não"]'
  createdAt DateTime    @default(now())

  answers BotAnswer[]
}

model BotSession {
  id             String    @id @default(uuid())
  phone          String
  currentStep    Int       @default(0)
  status         String    @default("IN_PROGRESS") // IN_PROGRESS | COMPLETED | CANCELLED
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  answers BotAnswer[]
}

model BotAnswer {
  id         String   @id @default(uuid())
  sessionId  String
  questionId String
  value      String
  createdAt  DateTime @default(now())

  session  BotSession  @relation(fields: [sessionId], references: [id])
  question BotQuestion @relation(fields: [questionId], references: [id])
}
